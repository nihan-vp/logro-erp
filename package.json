    "jspdf": "^4.2.1",
    "lucide-react": "^0.546.0",
    "megajs": "^1.3.10",
    "mongodb": "^7.2.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-toastify": "^11.1.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "vite": "^6.2.3"
  },
